# Claude API Key (required)
ANTHROPIC_API_KEY=your_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration (production only)
# Comma-separated list of allowed origins
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# SMTP Configuration (for user feedback emails)
# If not set, feedback is logged to the console only.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com, SMTP_PASS=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FEEDBACK_TO_EMAIL=
